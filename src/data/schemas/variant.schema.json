{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "variant.schema.json",
  "title": "Variant",
  "type": "object",
  "required": ["id", "name"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "image": {
      "type": "string"
    },
    "swatchColor": {
      "type": "string"
    }
  }
}
